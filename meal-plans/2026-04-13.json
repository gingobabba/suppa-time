        "title": "Crispy Chickpea and Lemon Tahini Kale Salad",
        "source": "Jenn Lueke",
        "source_type": "online",
        "source_url": "https://jenneatsgoood.com/crispy-chickpea-lemony-tahini-kale-salad/",
        "time_minutes": 45,
        "tags": ["vegetarian", "vegan", "gluten-free", "dairy-free"],
        "servings": 4,
        "ingredients": [
          { "item": "dry quinoa", "amount": "1 cup" },
          { "item": "shredded kale", "amount": "12 oz" },
          { "item": "chickpeas, drained and rinsed", "amount": "two 15-oz cans" },
          { "item": "olive oil", "amount": "1 tbsp + 1/4 cup" },
          { "item": "garlic powder", "amount": "1 tsp + 1 tsp" },
          { "item": "nutritional yeast", "amount": "1 tbsp + 1 tbsp" },
          { "item": "apple cider vinegar", "amount": "1/4 cup" },
          { "item": "coconut aminos", "amount": "2 tbsp" },
          { "item": "tahini", "amount": "1/4 cup" },
          { "item": "lemon, juiced", "amount": "1" },
          { "item": "warm water, for thinning", "amount": "as needed" }
        ],
        "steps": [
          "Preheat oven to 400°F and line a large sheet pan with parchment paper.",
          "Bring a pot of salted water to a boil. Add quinoa, reduce heat to low, cover, and cook until all liquid is absorbed, about 15 minutes.",
          "Spread drained chickpeas on the sheet pan and pat dry. Toss with 1 tbsp olive oil, 1 tsp salt, 1 tsp garlic powder, and 1 tbsp nutritional yeast. Bake until crisp, about 20 minutes.",
          "Make the dressing: whisk together 1/4 cup olive oil, apple cider vinegar, coconut aminos, tahini, lemon juice, 1/2 tsp salt, 1/2 tsp pepper, 1 tsp garlic powder, and 1 tbsp nutritional yeast. Thin with warm water 1 tbsp at a time as needed.",
          "Add kale to a large bowl. Pour over the dressing and massage it in with your hands until the kale softens.",
          "Add the cooked quinoa and crispy chickpeas to the bowl and toss to combine."
        ],
        "notes": ""
      }
