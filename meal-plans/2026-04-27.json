      "meal": {
        "title": "Maple Turkey Skillet with Sesame Ginger Rice",
        "source": "Jenn Lueke",
        "source_type": "online",
        "source_url": "https://jenneatsgoood.com/maple-turkey-skillet-with-sesame-ginger-rice/",
        "time_minutes": 45,
        "tags": ["gluten-free", "dairy-free"],
        "servings": 4,
        "ingredients": [
          { "item": "jasmine rice, rinsed", "amount": "1 cup" },
          { "item": "green onions, finely chopped", "amount": "4" },
          { "item": "fresh ginger, minced", "amount": "2 tsp" },
          { "item": "toasted sesame oil", "amount": "1 tbsp" },
          { "item": "ground turkey", "amount": "1 lb" },
          { "item": "carrots, cut into thin 2-inch strips", "amount": "2 large" },
          { "item": "celery ribs, cut into thin 2-inch strips", "amount": "4" },
          { "item": "garlic cloves, minced", "amount": "4" },
          { "item": "chili powder", "amount": "1/2 tsp" },
          { "item": "red pepper flakes (optional)", "amount": "1/4 tsp" },
          { "item": "coconut aminos", "amount": "1/3 cup" },
          { "item": "pure maple syrup", "amount": "2 tbsp" },
          { "item": "raw cashews", "amount": "1/2 cup" }
        ],
        "steps": [
          "Bring 2 cups of water to a boil. Add rice, reduce heat to low, cover, and cook until liquid is absorbed, 15–20 minutes. When done, stir in the green onions, 1 tsp ginger, sesame oil, and salt.",
          "Meanwhile, heat olive oil in a large skillet over medium-high. Add ground turkey and cook, breaking it up, until no pink remains, 4–5 minutes. Add carrots and celery and cook, stirring occasionally, until lightly browned, 6–8 minutes.",
          "Reduce heat to medium. Stir in garlic, remaining 1 tsp ginger, chili powder, and red pepper flakes; cook until fragrant, 1–2 minutes.",
          "Stir in coconut aminos and maple syrup and cook until sauce is slightly reduced, 3–4 minutes. Mix in cashews and cook 3 more minutes.",
          "Divide rice and turkey skillet among four bowls. Garnish with extra green onion."
        ],
        "notes": ""
      }
    },
