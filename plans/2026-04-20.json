        "title": "Chopped Broccoli Pesto White BEAN Salad",
        "source": "Jenn Lueke",
        "source_type": "online",
        "source_url": "https://jenneatsgoood.com/chopped-broccoli-pesto-white-bean-salad/",
        "time_minutes": 25,
        "tags": ["vegetarian", "vegan", "gluten-free", "dairy-free"],
        "servings": 4,
        "ingredients": [
          { "item": "cannellini or navy beans, drained and rinsed", "amount": "two 15-oz cans" },
          { "item": "kale, finely chopped", "amount": "2 cups packed" },
          { "item": "broccoli, finely chopped", "amount": "2 1/2 cups (1 1/2 for salad + 1 for pesto)" },
          { "item": "sun-dried tomatoes, finely chopped", "amount": "1/2 cup" },
          { "item": "basil leaves", "amount": "1 cup packed" },
          { "item": "lemon, juiced", "amount": "1" },
          { "item": "nutritional yeast", "amount": "2 tbsp" },
          { "item": "red wine vinegar", "amount": "2 tbsp" },
          { "item": "garlic clove", "amount": "1" },
          { "item": "olive oil", "amount": "1/3 cup" },
          { "item": "shelled hemp seeds", "amount": "3 tbsp" },
          { "item": "raw walnuts or pine nuts", "amount": "3 tbsp" }
        ],
        "steps": [
          "Make the broccoli pesto: in a food processor, combine walnuts, 1 cup chopped broccoli, basil, lemon juice, nutritional yeast, red wine vinegar, water, garlic, salt, and pepper. Process until smooth, about 45–60 seconds. Scrape sides, then slowly pour in olive oil while processing until fully incorporated.",
          "In a large bowl, combine the beans, kale, remaining 1 1/2 cups broccoli, and sun-dried tomatoes.",
          "Pour the broccoli pesto over the salad and toss to evenly coat. Sprinkle hemp seeds on top.",
          "Divide into containers and refrigerate — keeps well for up to 5 days."
        ],
        "notes": ""
      }
